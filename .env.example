DATABASE_HOST=mysql
# Application/database runtime port. In Docker Compose, webui talks to mysql on the
# internal service port 3306 regardless of the host-exposed MySQL port below.
DATABASE_PORT=3306
# Host-exposed MySQL port for tools running on your machine.
MYSQL_HOST_PORT=3306
DATABASE_NAME=hermes_webui
DATABASE_USER=hermes
DATABASE_PASSWORD=hermes
OBJECT_STORAGE_ENDPOINT=minio
# Internal MinIO service port used by the webui container.
OBJECT_STORAGE_PORT=9000
# Host-exposed MinIO API port for tools running on your machine.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORAGE_USE_SSL=false
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=hermes-webui
# Optional namespace/folder prefix inside the bucket (e.g. hermes-webui/prod).
OBJECT_STORAGE_PREFIX=
OBJECT_STORAGE_REGION=us-east-1
SESSION_COOKIE_NAME=hermes_webui_session
# Internal service auth for Hermes, not the browser login key.
HERMES_WEBCHAT_SERVICE_TOKEN=change-me
BRIEFING_RENDERER_BASE_URL=http://host.docker.internal:9910
BRIEFING_RENDERER_SERVICE_TOKEN=
BRIEFING_RENDERER_TIMEOUT_MS=15000
HERMES_EVENT_LEASE_SECONDS=120
# Consider worker heartbeat stale after this many seconds without Hermes poll/ack traffic.
HERMES_WORKER_HEARTBEAT_STALE_SECONDS=45
# Optional runtime diagnostics API. Leave blank to fail closed with 503.
DIAGNOSTICS_TOKEN=
DIAGNOSTICS_RING_BUFFER_SIZE=1000
DIAGNOSTICS_STALE_CHECK_INTERVAL_SECONDS=15
MAINTENANCE_TOKEN=
MAINTENANCE_COOKIE_NAME=hermes_webui_maintenance
BOOTSTRAP_USER_NAME=Owner
# Browser login key for the bootstrap owner account.
BOOTSTRAP_USER_KEY=dev-webui-key
PUBLIC_APP_NAME=Hermes WebUI
PUBLIC_MODEL_DISPLAY_NAME=Assistant
PUBLIC_MODEL_SIZE_LABEL=
PUBLIC_MODEL_CAPABILITY_LABEL=
PUBLIC_MODEL_FILE_LABEL=
# SvelteKit adapter-node request body size limit (supports units like 10M, 2G).
BODY_SIZE_LIMIT=10M
WEBUI_PORT=3000
__VITE_ADDITIONAL_SERVER_ALLOWED_HOSTS=example.local
MYSQL_ROOT_PASSWORD=root
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
